# Optional: point the client at your own PeerServer instead of the public default.
VITE_PEER_HOST=
VITE_PEER_PORT=
VITE_PEER_PATH=
VITE_PEER_SECURE=true
VITE_PEER_KEY=
VITE_PEER_DEBUG=1

# Optional: override ICE servers for production NAT traversal.
# Example:
# VITE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
VITE_ICE_SERVERS_JSON=
